APP_ENV=development
# Omit HTTP_ADDR to use PORT (e.g. Render). Local default is :8080.
HTTP_ADDR=:8080
# Aiven Postgres: use sslmode=require and enable pgvector.
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/spiritualmeet?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
# Set true for Aiven Redis and other TLS endpoints (host:port, not rediss://).
REDIS_TLS=false
JWT_SECRET=change-me
AUTO_MIGRATE=true
MESSAGE_REQUESTS_PER_MINUTE=12
MESSAGES_PER_MINUTE=60
AUTH_ATTEMPTS_PER_MINUTE=20
CORS_ALLOWED_ORIGINS=http://localhost:3000
